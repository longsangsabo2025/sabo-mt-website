# SABO M&T website (sabo.com.vn) — environment variables (example)
# Copy to .env.local and fill in real values.

# --- Supabase (DEDICATED project for sabo-mt-website) -------------------
# Create a NEW Supabase project (NOT the shared Longsang.org one).
# Apply migrations (order):
#   1. supabase/migrations/20260429_init_leads.sql
#   2. supabase/migrations/20260503_lead_engine.sql  (scoring + lead_conversations + demo_bookings)
# Get keys from: https://app.supabase.com/project/<your-ref>/settings/api
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- Telegram (lead notification to founder) ---------------------------
# Reuse from D:\0.PROJECTS\00-MASTER-ADMIN\admin\.env
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# --- Optional: Cloudflare Turnstile (anti-spam) ------------------------
# Free tier: https://dash.cloudflare.com/?to=/:account/turnstile
# When set, contact form will require captcha before submit.
# TURNSTILE_SECRET_KEY=
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# --- Optional: Site URL override ---------------------------------------
# Used by sitemap/robots/JSON-LD. Defaults to https://sabo.com.vn
# NEXT_PUBLIC_SITE_URL=https://sabo.com.vn

# --- Forge (long-sang-forge) shared backend ----------------------------
# Same Supabase project as longsang.org. Used for:
#   1. /api/booking → INSERT into `consultations` table (RLS allows anon insert)
#   2. /lib/showcase → SELECT from `project_showcase` (auto-sync case-studies)
# Project: https://app.supabase.com/project/diexsbzqwsbpilsymnfb
FORGE_SUPABASE_URL=https://diexsbzqwsbpilsymnfb.supabase.co
FORGE_SUPABASE_ANON_KEY=
# Service role bypasses RLS — REQUIRED for project_showcase reads (server-side only).
# Never expose to browser. Get from: Supabase Dashboard → Settings → API → service_role.
FORGE_SUPABASE_SERVICE_ROLE_KEY=

# --- On-demand revalidation webhook ------------------------------------
# Forge admin calls POST /api/revalidate when project_showcase rows change.
# Generate with: openssl rand -hex 32
REVALIDATE_SECRET=

# --- Groq (AI chat widget) --------------------------------------------
# Free tier at https://console.groq.com/keys
GROQ_API_KEY=

# --- Plausible Analytics (privacy-friendly, no cookies) ----------------
# Sign up: https://plausible.io  (or self-host: https://plausible.io/docs/self-hosting)
# Set domain to enable — leave blank to disable analytics entirely.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=sabo.com.vn
# Optional: override script src for self-hosted instance.
# NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.outbound-links.js

# --- SaboHub Portal (SSO) ----------------------------------------------
# Supabase project của SaboHub (dqddxowyikefqcdiioyh) — dùng cho /portal login
# CEO/Manager login tại sabo.com.vn/portal → redirect vào hub.sabo.com.vn tự động
NEXT_PUBLIC_SABOHUB_SUPABASE_URL=https://dqddxowyikefqcdiioyh.supabase.co
NEXT_PUBLIC_SABOHUB_SUPABASE_ANON_KEY=
# URL của SaboHub web dashboard (dùng cho SSO redirect)
NEXT_PUBLIC_HUB_URL=https://hub.sabo.com.vn
# Local URL của SaboHub khi dev trên localhost (fallback tự động ở dev mode)
NEXT_PUBLIC_HUB_LOCAL_URL=http://localhost:9000

# --- Optional: Forward contact form to external CRM --------------------
# When set, /api/contact will POST a copy to this URL (e.g. longsang.org API).
# Payload: { name, email, phone, company, message, source, submitted_at }
# CONTACT_FORWARD_URL=https://longsang.org/api/leads